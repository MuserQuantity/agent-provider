# 复制为 .env 使用（.env 已被 gitignore，不会提交）。
# 优先级：命令行参数 > 真实环境变量 > .env 文件 > 默认值

# 服务访问密钥；客户端需带 Authorization: Bearer <key>。留空或删除则不鉴权
AGENT_PROVIDER_API_KEY=sk-change-me

# 监听地址（默认 127.0.0.1:8080，仅本机可访问）
#AGENT_PROVIDER_ADDR=127.0.0.1:8080

# 注入给 CLI 子进程的代理（默认 http://127.0.0.1:7890）；填 none 表示不用代理（服务器部署常用）
#AGENT_PROVIDER_PROXY=http://127.0.0.1:7890
#AGENT_PROVIDER_PROXY=none

# CLI 子进程的工作目录
#AGENT_PROVIDER_WORKDIR=.

# 单次 CLI 执行超时（Go duration 格式：30s、5m、1h）
#AGENT_PROVIDER_TIMEOUT=10m
